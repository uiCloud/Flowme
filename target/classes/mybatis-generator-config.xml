<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="MySQLContext" targetRuntime="MyBatis3" defaultModelType="flat">
        <!-- 配置数据库连接信息 -->
        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/ticket?useUnicode=true&amp;characterEncoding=utf-8&amp;useSSL=false&amp;serverTimezone=Asia/Shanghai"
                        userId="root"
                        password="root">
            <!-- 只生成ticket数据库中的表 -->
            <property name="nullCatalogMeansCurrent" value="true" />
        </jdbcConnection>

        <!-- 配置生成的实体类的位置 -->
        <javaModelGenerator targetPackage="com.qiubw.domain.entity" targetProject="src/main/java">
            <property name="enableSubPackages" value="true" />
            <property name="trimStrings" value="true" />
        </javaModelGenerator>

        <!-- 配置生成的Mapper接口的位置 -->
        <sqlMapGenerator targetPackage="mapper" targetProject="src/main/resources">
            <property name="enableSubPackages" value="true" />
        </sqlMapGenerator>

        <!-- 配置生成的Mapper XML文件的位置 -->
        <javaClientGenerator type="XMLMAPPER" targetPackage="com.qiubw.repository.mapper" targetProject="src/main/java">
            <property name="enableSubPackages" value="true" />
        </javaClientGenerator>

        <!-- 配置要生成的表 -->
        <table tableName="user" domainObjectName="User" />
        <table tableName="role" domainObjectName="Role" />
        <table tableName="ticket" domainObjectName="Ticket" />
        <table tableName="ticket_type" domainObjectName="TicketType" />
        <table tableName="permission" domainObjectName="Permission" />
        <table tableName="menu" domainObjectName="Menu" />
        <table tableName="role_permission" domainObjectName="RolePermission" />
    </context>
</generatorConfiguration>